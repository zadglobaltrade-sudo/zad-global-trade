---
// Zad Global Trade - Certifications & Compliance Page
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>Certifications & Compliance — Zad Global Trade</title>
  <meta name="description" content="Zad Global Trade holds all required export certifications and compliances for fresh produce export from India including APEDA, IEC, FSSAI and Phytosanitary." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --green-dark: #1B4332;
      --green-mid: #2D6A4F;
      --gold: #C9963E;
      --gold-light: #E8B96A;
      --offwhite: #FAF7F2;
      --charcoal: #1C1C1C;
      --grey: #6B6B6B;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--offwhite);
      color: var(--charcoal);
      overflow-x: hidden;
    }

    h1, h2, h3 { font-family: 'Playfair Display', serif; }

    /* ─── POPUP OVERLAY ─── */
    .popup-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      backdrop-filter: blur(4px);
    }

    .popup-box {
      background: var(--offwhite);
      max-width: 480px;
      width: 100%;
      padding: 3rem 2.5rem;
      position: relative;
      animation: popupIn 0.3s ease;
    }

    @keyframes popupIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .popup-label {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      display: block;
      margin-bottom: 0.8rem;
    }

    .popup-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--green-dark);
      line-height: 1.2;
      margin-bottom: 0.8rem;
    }

    .popup-desc {
      font-size: 0.85rem;
      color: var(--grey);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 1.8rem;
    }

    .popup-field {
      margin-bottom: 1rem;
    }

    .popup-field label {
      display: block;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--green-dark);
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .popup-field input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid rgba(0,0,0,0.12);
      background: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      color: var(--charcoal);
      outline: none;
      transition: border-color 0.2s;
    }

    .popup-field input:focus {
      border-color: var(--gold);
    }

    .popup-field input.error {
      border-color: #c0392b;
    }

    .field-error {
      font-size: 0.72rem;
      color: #c0392b;
      margin-top: 0.3rem;
      display: none;
    }

    .field-error.visible { display: block; }

    .popup-submit {
      width: 100%;
      background: var(--green-dark);
      color: white;
      border: none;
      padding: 0.9rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      margin-top: 0.5rem;
      transition: background 0.2s;
    }

    .popup-submit:hover { background: var(--green-mid); }

    .popup-skip {
      display: block;
      text-align: center;
      margin-top: 1rem;
      font-size: 0.75rem;
      color: var(--grey);
      cursor: pointer;
      text-decoration: underline;
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      width: 100%;
    }

    .popup-skip:hover { color: var(--charcoal); }

    /* Thank you state */
    .popup-thankyou {
      display: none;
      text-align: center;
      padding: 1rem 0;
    }

    .popup-thankyou-icon {
      font-size: 2.5rem;
      display: block;
      margin-bottom: 1rem;
    }

    .popup-thankyou h3 {
      font-size: 1.4rem;
      color: var(--green-dark);
      margin-bottom: 0.6rem;
    }

    .popup-thankyou p {
      font-size: 0.85rem;
      color: var(--grey);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .popup-thankyou-btn {
      background: var(--gold);
      color: white;
      border: none;
      padding: 0.8rem 2rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: background 0.2s;
    }

    .popup-thankyou-btn:hover { background: var(--gold-light); }

    /* ─── NAVBAR ─── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--green-dark);
      padding: 0 3rem;
      box-shadow: 0 2px 20px rgba(0,0,0,0.2);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .nav-logo img { height: 44px; width: auto; }

    .nav-logo span {
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a.active { color: white; border-bottom: 2px solid var(--gold); padding-bottom: 2px; }
    .nav-icon { color: rgba(255,255,255,0.7); font-size: 1.1rem; }

    /* ─── PAGE HERO ─── */
    .page-hero {
      background: var(--green-dark);
      padding: 9rem 3rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(201,150,62,0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .page-hero-label {
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      display: block;
      margin-bottom: 1.2rem;
    }

    .page-hero h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      color: white;
      line-height: 1.15;
      margin-bottom: 1.2rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    .page-hero-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ─── SHARED ─── */
    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 0.8rem;
      display: block;
    }

    /* ─── INTRO ─── */
    .intro-section {
      padding: 5rem 3rem;
      background: var(--offwhite);
      text-align: center;
    }

    .intro-inner {
      max-width: 800px;
      margin: 0 auto;
    }

    .intro-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--green-dark);
      line-height: 1.25;
      margin-bottom: 1.2rem;
    }

    .intro-text {
      font-size: 0.95rem;
      color: var(--grey);
      line-height: 1.9;
      font-weight: 300;
    }

    /* ─── CERT CARDS ─── */
    .certs-section {
      padding: 5rem 3rem;
      background: white;
    }

    .certs-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .certs-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .certs-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--green-dark);
    }

    .certs-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .cert-card {
      border: 1px solid rgba(0,0,0,0.08);
      padding: 2rem 1.5rem;
      background: var(--offwhite);
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      position: relative;
      transition: border-color 0.3s, transform 0.3s;
    }

    .cert-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
    }

    .cert-icon {
      font-size: 1.8rem;
      display: block;
    }

    .cert-tag {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 600;
      padding: 0.25rem 0.6rem;
    }

    .cert-tag.active {
      background: rgba(27,67,50,0.1);
      color: var(--green-dark);
    }

    .cert-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: var(--green-dark);
      line-height: 1.2;
    }

    .cert-issuer {
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
    }

    .cert-desc {
      font-size: 0.8rem;
      color: var(--grey);
      line-height: 1.65;
      font-weight: 300;
      flex-grow: 1;
    }

    .cert-divider {
      height: 1px;
      background: rgba(0,0,0,0.06);
    }

    .cert-request {
      font-size: 0.75rem;
      color: var(--green-dark);
      font-weight: 600;
      letter-spacing: 0.05em;
      cursor: pointer;
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      padding: 0;
      text-align: left;
      transition: color 0.2s;
    }

    .cert-request:hover { color: var(--gold); }

    /* ─── PER SHIPMENT SECTION ─── */
    .shipment-section {
      background: var(--green-dark);
      padding: 5rem 3rem;
    }

    .shipment-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .shipment-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .shipment-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.4rem);
      color: white;
    }

    .shipment-header .section-label { color: var(--gold); }

    .shipment-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .shipment-card {
      border: 1px solid rgba(255,255,255,0.1);
      padding: 2rem 1.5rem;
      transition: border-color 0.3s;
    }

    .shipment-card:hover { border-color: var(--gold); }

    .shipment-icon {
      font-size: 1.5rem;
      display: block;
      margin-bottom: 0.8rem;
      color: var(--gold);
    }

    .shipment-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: white;
      margin-bottom: 0.6rem;
    }

    .shipment-desc {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.65;
      font-weight: 300;
    }

    /* ─── COMPLIANCE STANDARDS ─── */
    .standards-section {
      padding: 5rem 3rem;
      background: var(--offwhite);
    }

    .standards-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .standards-text h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: var(--green-dark);
      line-height: 1.25;
      margin-bottom: 1.2rem;
    }

    .standards-text p {
      font-size: 0.9rem;
      color: var(--grey);
      line-height: 1.85;
      font-weight: 300;
      margin-bottom: 1rem;
    }

    .standards-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin-top: 1.5rem;
    }

    .standards-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.8rem;
      font-size: 0.85rem;
      color: var(--charcoal);
      font-weight: 400;
    }

    .standards-list li::before {
      content: '✓';
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .standards-visual {
      background: var(--green-dark);
      padding: 3rem;
    }

    .standards-visual-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--gold);
      font-style: italic;
      margin-bottom: 1.5rem;
    }

    .standard-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .standard-row:last-child { border-bottom: none; }

    .standard-name {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.75);
      font-weight: 400;
    }

    .standard-check {
      font-size: 0.75rem;
      color: var(--gold);
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    /* ─── CTA ─── */
    .cta-banner {
      background: var(--green-dark);
      padding: 5rem 3rem;
      text-align: center;
    }

    .cta-banner-inner { max-width: 700px; margin: 0 auto; }

    .cta-banner h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: white;
      margin-bottom: 1rem;
    }

    .cta-banner p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .btn-gold {
      display: inline-block;
      background: var(--gold);
      color: white;
      padding: 0.9rem 2.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-gold:hover { background: var(--gold-light); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--green-dark);
      padding: 4rem 3rem 0;
      border-top: 1px solid var(--gold);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }

    .footer-brand-name {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.12em;
      color: white;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.8rem;
    }

    .footer-tagline {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 1.4rem;
    }

    .footer-socials { display: flex; gap: 0.6rem; }

    .footer-social-btn {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      transition: border-color 0.2s, color 0.2s;
    }

    .footer-social-btn:hover { border-color: var(--gold); color: var(--gold); }

    .footer-col-title {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 1.2rem;
      display: block;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-links a {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      transition: color 0.2s;
      font-weight: 300;
    }

    .footer-links a:hover { color: white; }

    .footer-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      margin-bottom: 0.8rem;
    }

    .footer-contact-icon { color: var(--gold); font-size: 0.85rem; margin-top: 2px; flex-shrink: 0; }
    .footer-contact-text { font-size: 0.82rem; color: rgba(255,255,255,0.6); line-height: 1.5; font-weight: 300; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.4rem 0;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.35); letter-spacing: 0.05em; }
    .footer-badges { display: flex; gap: 1.5rem; }
    .footer-badge { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .certs-grid { grid-template-columns: repeat(2, 1fr); }
      .shipment-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      #navbar { padding: 0 1.2rem; }
      .nav-links { display: none; }
      .page-hero { padding: 7rem 1.2rem 3.5rem; }
      .intro-section { padding: 4rem 1.2rem; }
      .certs-section { padding: 4rem 1.2rem; }
      .certs-grid { grid-template-columns: 1fr 1fr; }
      .shipment-section { padding: 4rem 1.2rem; }
      .shipment-grid { grid-template-columns: 1fr; }
      .standards-section { padding: 4rem 1.2rem; }
      .standards-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .cta-banner { padding: 4rem 1.2rem; }
      .popup-box { padding: 2rem 1.5rem; }
    }

    @media (max-width: 480px) {
      .certs-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>

  <!-- ═══════════════════════════════════════
       POPUP — fires on page load
  ═══════════════════════════════════════ -->
  <div class="popup-overlay" id="popupOverlay">
    <div class="popup-box">

      <!-- Form state -->
      <div id="popupForm">
        <span class="popup-label">Before You Continue</span>
        <h2 class="popup-title">Access Our Certifications</h2>
        <p class="popup-desc">Please share your name and email to view our compliance documents. We will follow up with any documentation you need for your import process.</p>

        <div class="popup-field">
          <label for="visitorName">Your Name</label>
          <input type="text" id="visitorName" placeholder="e.g. Ahmed Al Rashid" autocomplete="name" />
          <span class="field-error" id="nameError">Please enter your name.</span>
        </div>

        <div class="popup-field">
          <label for="visitorEmail">Business Email</label>
          <input type="email" id="visitorEmail" placeholder="e.g. ahmed@company.com" autocomplete="email" />
          <span class="field-error" id="emailError">Please enter a valid email address.</span>
        </div>

        <button class="popup-submit" id="popupSubmit">Continue to Certifications</button>
        <button class="popup-skip" id="popupSkip">Skip for now</button>
      </div>

      <!-- Thank you state -->
      <div class="popup-thankyou" id="popupThankyou">
        <span class="popup-thankyou-icon">✅</span>
        <h3>Thank You!</h3>
        <p>We have noted your details. Our team will reach out if you need specific documentation for your import process.</p>
        <button class="popup-thankyou-btn" id="popupClose">View Certifications</button>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════ -->
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/images/logo.png" alt="Zad Global Trade" onerror="this.style.display='none'" />
        <span>Zad Global Trade</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/certifications" class="active">Certifications</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <span class="nav-icon">🌿</span>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════
       PAGE HERO
  ═══════════════════════════════════════ -->
  <section class="page-hero">
    <span class="page-hero-label">Trust & Compliance</span>
    <h1>Certified, Compliant<br/>& Export Ready</h1>
    <p class="page-hero-sub">Every shipment from Zad Global Trade is backed by the required regulatory certifications and international compliance standards.</p>
  </section>

  <!-- ═══════════════════════════════════════
       INTRO
  ═══════════════════════════════════════ -->
