---
// Zad Global Trade - Services Page
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>Services — Zad Global Trade</title>
  <meta name="description" content="End-to-end fresh produce export services from Pune, India. From farm procurement to freight forwarding and delivery across Asia and the Middle East." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --green-dark: #1B4332;
      --green-mid: #2D6A4F;
      --gold: #C9963E;
      --gold-light: #E8B96A;
      --offwhite: #FAF7F2;
      --charcoal: #1C1C1C;
      --grey: #6B6B6B;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--offwhite);
      color: var(--charcoal);
    }

    h1, h2, h3 { font-family: 'Playfair Display', serif; }

    /* ─── NAVBAR ─── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--green-dark);
      padding: 0 3rem;
      box-shadow: 0 2px 20px rgba(0,0,0,0.2);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .nav-logo img { height: 44px; width: auto; }

    .nav-logo span {
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a.active { color: white; border-bottom: 2px solid var(--gold); padding-bottom: 2px; }
    .nav-icon { color: rgba(255,255,255,0.7); font-size: 1.1rem; }

    /* ─── PAGE HERO ─── */
    .page-hero {
      background: var(--green-dark);
      padding: 9rem 3rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(201,150,62,0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .page-hero-label {
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      display: block;
      margin-bottom: 1.2rem;
    }

    .page-hero h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      color: white;
      line-height: 1.15;
      margin-bottom: 1.2rem;
      max-width: 750px;
      margin-left: auto;
      margin-right: auto;
    }

    .page-hero-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ─── INTRO STATEMENT ─── */
    .intro-section {
      padding: 5rem 3rem;
      background: var(--offwhite);
    }

    .intro-inner {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }

    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 0.8rem;
      display: block;
    }

    .intro-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--green-dark);
      line-height: 1.25;
      margin-bottom: 1.4rem;
    }

    .intro-text {
      font-size: 1rem;
      color: var(--grey);
      line-height: 1.9;
      font-weight: 300;
      max-width: 720px;
      margin: 0 auto;
    }

    /* ─── TIMELINE ─── */
    .timeline-section {
      background: var(--green-dark);
      padding: 6rem 3rem;
    }

    .timeline-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .timeline-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .timeline-header h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: white;
    }

    .timeline-header .section-label {
      color: var(--gold);
    }

    /* Desktop: horizontal timeline */
    .timeline {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      position: relative;
      gap: 0;
    }

    /* Connecting line */
    .timeline::before {
      content: '';
      position: absolute;
      top: 28px;
      left: 10%;
      right: 10%;
      height: 1px;
      background: rgba(201,150,62,0.3);
      z-index: 0;
    }

    .timeline-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1rem;
      position: relative;
      z-index: 1;
    }

    .step-number {
      width: 56px;
      height: 56px;
      border: 1.5px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: var(--gold);
      background: var(--green-dark);
      margin-bottom: 1.4rem;
      flex-shrink: 0;
    }

    .step-icon {
      font-size: 1.2rem;
      display: block;
      margin-bottom: 0.6rem;
      color: var(--gold);
    }

    .step-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: white;
      margin-bottom: 0.5rem;
    }

    .step-desc {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
      font-weight: 300;
    }

    /* ─── SERVICES GRID ─── */
    .services-section {
      padding: 6rem 3rem;
      background: var(--offwhite);
    }

    .services-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .services-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .services-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--green-dark);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .service-card {
      background: white;
      padding: 2.5rem 2rem;
      border-bottom: 3px solid transparent;
      transition: border-color 0.3s, transform 0.3s;
    }

    .service-card:hover {
      border-color: var(--gold);
      transform: translateY(-4px);
    }

    .service-icon {
      font-size: 1.8rem;
      display: block;
      margin-bottom: 1rem;
    }

    .service-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      color: var(--green-dark);
      margin-bottom: 0.8rem;
    }

    .service-desc {
      font-size: 0.85rem;
      color: var(--grey);
      line-height: 1.75;
      font-weight: 300;
      margin-bottom: 1.2rem;
    }

    .service-points {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .service-points li {
      font-size: 0.78rem;
      color: var(--grey);
      font-weight: 300;
      padding-left: 1rem;
      position: relative;
    }

    .service-points li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--gold);
      font-size: 0.7rem;
    }

    /* ─── PARTNER TRUST SECTION ─── */
    .partner-section {
      background: white;
      padding: 5rem 3rem;
    }

    .partner-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .partner-text .section-label { margin-bottom: 0.8rem; }

    .partner-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: var(--green-dark);
      line-height: 1.25;
      margin-bottom: 1.2rem;
    }

    .partner-desc {
      font-size: 0.92rem;
      color: var(--grey);
      line-height: 1.85;
      font-weight: 300;
      margin-bottom: 1.5rem;
    }

    .partner-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
      margin-top: 1rem;
    }

    .partner-stat {
      padding: 1.2rem;
      border: 1px solid rgba(0,0,0,0.07);
      background: var(--offwhite);
    }

    .partner-stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--green-dark);
      display: block;
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .partner-stat-label {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--grey);
      font-weight: 500;
    }

    .partner-visual {
      background: var(--green-dark);
      padding: 3rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .partner-visual-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--gold);
      font-style: italic;
      margin-bottom: 0.5rem;
    }

    .capability-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .capability-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .capability-icon {
      color: var(--gold);
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .capability-title {
      font-size: 0.85rem;
      color: white;
      font-weight: 600;
      margin-bottom: 0.2rem;
      display: block;
    }

    .capability-desc {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      font-weight: 300;
      line-height: 1.5;
    }

    /* ─── MARKETS SECTION ─── */
    .markets-section {
      background: var(--offwhite);
      padding: 5rem 3rem;
      text-align: center;
    }

    .markets-inner {
      max-width: 1000px;
      margin: 0 auto;
    }

    .markets-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: var(--green-dark);
      margin-bottom: 0.8rem;
    }

    .markets-desc {
      font-size: 0.92rem;
      color: var(--grey);
      font-weight: 300;
      line-height: 1.7;
      margin-bottom: 3rem;
    }

    .markets-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: rgba(0,0,0,0.06);
      border: 1px solid rgba(0,0,0,0.06);
      max-width: 700px;
      margin: 0 auto 2rem;
    }

    .market-item {
      background: white;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .market-flag {
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    .market-name {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--green-dark);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .market-region {
      font-size: 0.72rem;
      color: var(--grey);
      font-weight: 300;
    }

    /* ─── CTA BANNER ─── */
    .cta-banner {
      background: var(--green-dark);
      padding: 5rem 3rem;
      text-align: center;
    }

    .cta-banner-inner { max-width: 700px; margin: 0 auto; }

    .cta-banner h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: white;
      margin-bottom: 1rem;
    }

    .cta-banner p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .btn-gold {
      display: inline-block;
      background: var(--gold);
      color: white;
      padding: 0.9rem 2.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-gold:hover { background: var(--gold-light); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--green-dark);
      padding: 4rem 3rem 0;
      border-top: 1px solid var(--gold);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }

    .footer-brand-name {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.12em;
      color: white;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.8rem;
    }

    .footer-tagline {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 1.4rem;
    }

    .footer-socials { display: flex; gap: 0.6rem; }

    .footer-social-btn {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      transition: border-color 0.2s, color 0.2s;
    }

    .footer-social-btn:hover { border-color: var(--gold); color: var(--gold); }

    .footer-col-title {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 1.2rem;
      display: block;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-links a {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      transition: color 0.2s;
      font-weight: 300;
    }

    .footer-links a:hover { color: white; }

    .footer-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      margin-bottom: 0.8rem;
    }

    .footer-contact-icon { color: var(--gold); font-size: 0.85rem; margin-top: 2px; flex-shrink: 0; }
    .footer-contact-text { font-size: 0.82rem; color: rgba(255,255,255,0.6); line-height: 1.5; font-weight: 300; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.4rem 0;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.35); letter-spacing: 0.05em; }
    .footer-badges { display: flex; gap: 1.5rem; }
    .footer-badge { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .timeline { grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .timeline::before { display: none; }
    }

    @media (max-width: 768px) {
      #navbar { padding: 0 1.2rem; }
      .nav-links { display: none; }
      .page-hero { padding: 7rem 1.2rem 3.5rem; }
      .intro-section { padding: 4rem 1.2rem; }
      .timeline-section { padding: 4rem 1.2rem; }
      .timeline { grid-template-columns: 1fr 1fr; }
      .services-section { padding: 4rem 1.2rem; }
      .services-grid { grid-template-columns: 1fr; }
      .partner-section { padding: 4rem 1.2rem; }
      .partner-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .markets-section { padding: 4rem 1.2rem; }
      .markets-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .cta-banner { padding: 4rem 1.2rem; }
    }
  </style>
</head>

<body>

  <!-- ═══════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════ -->
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/images/logo.png" alt="Zad Global Trade" onerror="this.style.display='none'" />
        <span>Zad Global Trade</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/services" class="active">Services</a></li>
        <li><a href="/certifications">Certifications</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <span class="nav-icon">🌿</span>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════
       PAGE HERO
  ═══════════════════════════════════════ -->
  <section class="page-hero">
    <span class="page-hero-label">What We Do</span>
    <h1>End-to-End Export,<br/>Handled for You</h1>
    <p class="page-hero-sub">From sourcing at the farm to delivery at your port — we manage every step so you can focus on your business.</p>
  </section>

  <!-- ═══════════════════════════════════════
       INTRO STATEMENT
  ═══════════════════════════════════════ -->
  <section class="intro-section">
    <div class="intro-inner">
      <span class="section-label">Our Proposition</span>
      <h2 class="intro-title">From Sourcing to Shipment &mdash; Handled Properly</h2>
      <p class="intro-text">Zad Global Trade is not just a produce supplier — we are your complete export partner. With direct access to certified farms, established freight forwarding connections and full documentation capability, we remove every friction point between Indian farms and your warehouse. One point of contact. Zero complexity.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TIMELINE
  ═══════════════════════════════════════ -->
  <section class="timeline-section">
    <div class="timeline-inner">
      <div class="timeline-header">
        <span class="section-label">How It Works</span>
        <h2>From Farm to Your Shore</h2>
      </div>

      <div class="timeline">

        <div class="timeline-step">
          <div class="step-number">01</div>
          <span class="step-icon">🌱</span>
          <h3 class="step-title">Procurement</h3>
          <p class="step-desc">We source directly from certified farms with men on the ground at harvest sites across Maharashtra.</p>
        </div>

        <div class="timeline-step">
          <div class="step-number">02</div>
          <span class="step-icon">✅</span>
          <h3 class="step-title">Quality & Grading</h3>
          <p class="step-desc">Every batch is inspected, graded and sorted to your specification before packing begins.</p>
        </div>

        <div class="timeline-step">
          <div class="step-number">03</div>
          <span class="step-icon">📦</span>
          <h3 class="step-title">Packing & Cold Chain</h3>
          <p class="step-desc">Export-grade packaging with cold chain management to preserve freshness throughout transit.</p>
        </div>

        <div class="timeline-step">
          <div class="step-number">04</div>
          <span class="step-icon">📋</span>
          <h3 class="step-title">Export Documentation</h3>
          <p class="step-desc">We handle all export paperwork — phytosanitary certificates, APEDA, customs clearance and more.</p>
        </div>

        <div class="timeline-step">
          <div class="step-number">05</div>
          <span class="step-icon">🚢</span>
          <h3 class="step-title">Freight & Delivery</h3>
          <p class="step-desc">Sea or air freight arranged through our established forwarding network, delivered to your destination port.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVICES GRID
  ═══════════════════════════════════════ -->
  <section class="services-section">
    <div class="services-inner">

      <div class="services-header">
        <span class="section-label">Our Services</span>
        <h2>Everything You Need,<br/>Under One Roof</h2>
      </div>

      <div class="services-grid">

        <div class="service-card">
          <span class="service-icon">🌾</span>
          <h3 class="service-title">Farm Procurement</h3>
          <p class="service-desc">We maintain direct relationships with certified pomegranate and banana farms across Maharashtra. You get farm-fresh produce without dealing with multiple suppliers.</p>
          <ul class="service-points">
            <li>Direct farm access — no middlemen</li>
            <li>Ground-level harvest monitoring</li>
            <li>Consistent supply across seasons</li>
          </ul>
        </div>

        <div class="service-card">
          <span class="service-icon">🔍</span>
          <h3 class="service-title">Quality Inspection & Grading</h3>
          <p class="service-desc">Every shipment goes through a rigorous grading process aligned to international import standards. We sort by size, colour, weight and brix levels as required.</p>
          <ul class="service-points">
            <li>Pre-shipment quality checks</li>
            <li>Size and grade sorting</li>
            <li>Phytosanitary compliance</li>
          </ul>
        </div>

        <div class="service-card">
          <span class="service-icon">❄️</span>
          <h3 class="service-title">Cold Chain & Packaging</h3>
