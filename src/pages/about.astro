---
// Zad Global Trade - About Us Page
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>About Us — Zad Global Trade</title>
  <meta name="description" content="Learn about Zad Global Trade, a premium fresh produce export company based in Pune, India. Exporting Pomegranates and Bananas globally with trust and quality." />

  <!-- Google Fonts: Playfair Display + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --green-dark: #1B4332;
      --green-mid: #2D6A4F;
      --gold: #C9963E;
      --gold-light: #E8B96A;
      --offwhite: #FAF7F2;
      --charcoal: #1C1C1C;
      --grey: #6B6B6B;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--offwhite);
      color: var(--charcoal);
    }

    h1, h2, h3 {
      font-family: 'Playfair Display', serif;
    }

    /* ─── NAVBAR ─── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--green-dark);
      padding: 0 3rem;
      box-shadow: 0 2px 20px rgba(0,0,0,0.2);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .nav-logo img {
      height: 44px;
      width: auto;
    }

    .nav-logo span {
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a.active { color: white; border-bottom: 2px solid var(--gold); padding-bottom: 2px; }

    .nav-icon { color: rgba(255,255,255,0.7); font-size: 1.1rem; }

    /* ─── PAGE HERO ─── */
    .page-hero {
      background: var(--green-dark);
      padding: 9rem 3rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(201,150,62,0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .page-hero-label {
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      display: block;
      margin-bottom: 1.2rem;
    }

    .page-hero h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      color: white;
      line-height: 1.15;
      margin-bottom: 1.2rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    .page-hero-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      letter-spacing: 0.03em;
    }

    /* ─── SHARED SECTION STYLES ─── */
    .section {
      padding: 6rem 3rem;
    }

    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 0.8rem;
      display: block;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      color: var(--green-dark);
      line-height: 1.2;
      margin-bottom: 1.4rem;
    }

    /* ─── OUR STORY ─── */
    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .story-image {
      position: relative;
    }

    /* REPLACE: Add your story image to /public/images/about-story.jpg */
    .story-image img {
      width: 100%;
      height: 500px;
      object-fit: cover;
      display: block;
    }

    .story-image-placeholder {
      width: 100%;
      height: 500px;
      background: var(--green-mid);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.3);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
    }

    .story-text p {
      color: var(--grey);
      line-height: 1.85;
      font-size: 0.95rem;
      font-weight: 300;
      margin-bottom: 1.2rem;
    }

    .story-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--gold);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-decoration: none;
      margin-top: 0.5rem;
      border-bottom: 1px solid var(--gold);
      padding-bottom: 2px;
      transition: color 0.2s;
    }

    .story-link:hover { color: var(--gold-light); }

    /* ─── MISSION & VALUES ─── */
    .values-section {
      background: var(--green-dark);
      padding: 6rem 3rem;
    }

    .values-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .values-heading {
      text-align: center;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      color: white;
      margin-bottom: 3.5rem;
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .value-card {
      border: 1px solid rgba(255,255,255,0.12);
      padding: 2.5rem 2rem;
      text-align: center;
      transition: border-color 0.3s;
    }

    .value-card:hover {
      border-color: var(--gold);
    }

    .value-icon {
      font-size: 2rem;
      display: block;
      margin-bottom: 1rem;
      color: var(--gold);
    }

    .value-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: white;
      margin-bottom: 0.8rem;
    }

    .value-desc {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      font-weight: 300;
    }

    /* ─── VIDEO SECTION ─── */
    .video-section {
      background: var(--offwhite);
      padding: 6rem 3rem;
      text-align: center;
    }

    .video-inner {
      max-width: 900px;
      margin: 0 auto;
    }

    .video-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      color: var(--green-dark);
      margin-bottom: 2.5rem;
    }

    .video-wrapper {
      position: relative;
      width: 100%;
      padding-bottom: 56.25%; /* 16:9 ratio */
      background: var(--green-dark);
      overflow: hidden;
    }

    .video-wrapper iframe {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    /* Placeholder shown when no video yet */
    .video-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      cursor: pointer;
    }

    .video-play-btn {
      width: 72px;
      height: 72px;
      border: 2px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gold);
      font-size: 1.6rem;
      transition: background 0.3s, color 0.3s;
    }

    .video-play-btn:hover {
      background: var(--gold);
      color: white;
    }

    .video-placeholder-text {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }

    /* ─── GALLERY ─── */
    .gallery-section {
      background: var(--offwhite);
      padding: 6rem 3rem;
    }

    .gallery-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .gallery-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    /* Puzzle grid layout */
    .gallery-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 2fr 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 8px;
      height: 560px;
      border-radius: 12px;
      overflow: hidden;
    }

    .gallery-item {
      overflow: hidden;
      position: relative;
    }

    /* Left top */
    .gallery-item:nth-child(1) {
      grid-column: 1;
      grid-row: 1;
    }

    /* Left bottom */
    .gallery-item:nth-child(2) {
      grid-column: 1;
      grid-row: 2;
    }

    /* Center large -- spans both rows */
    .gallery-item:nth-child(3) {
      grid-column: 2 / 5;
      grid-row: 1 / 3;
    }

    /* Right top */
    .gallery-item:nth-child(4) {
      grid-column: 5;
      grid-row: 1;
    }

    /* Right bottom */
    .gallery-item:nth-child(5) {
      grid-column: 5;
      grid-row: 2;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), filter 0.4s ease;
    }

    .gallery-item:hover img {
      transform: scale(1.03);
      filter: brightness(0.95);
    }

    /* Placeholder for missing gallery images */
    .gallery-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
    }

    .gallery-placeholder-1 { background: #2D5A3D; }
    .gallery-placeholder-2 { background: #1B4332; }
    .gallery-placeholder-3 { background: #3D6B4F; }
    .gallery-placeholder-4 { background: #254D38; }
    .gallery-placeholder-5 { background: #1A3D2B; }

    /* ─── FOOTER ─── */
    footer {
      background: var(--green-dark);
      padding: 4rem 3rem 0;
      border-top: 1px solid var(--gold);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }

    .footer-brand-name {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.12em;
      color: white;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.8rem;
    }

    .footer-tagline {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 1.4rem;
    }

    .footer-socials {
      display: flex;
      gap: 0.6rem;
    }

    .footer-social-btn {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      transition: border-color 0.2s, color 0.2s;
    }

    .footer-social-btn:hover { border-color: var(--gold); color: var(--gold); }

    .footer-col-title {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 1.2rem;
      display: block;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-links a {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      transition: color 0.2s;
      font-weight: 300;
    }

    .footer-links a:hover { color: white; }

    .footer-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      margin-bottom: 0.8rem;
    }

    .footer-contact-icon { color: var(--gold); font-size: 0.85rem; margin-top: 2px; flex-shrink: 0; }
    .footer-contact-text { font-size: 0.82rem; color: rgba(255,255,255,0.6); line-height: 1.5; font-weight: 300; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.4rem 0;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.35); letter-spacing: 0.05em; }

    .footer-badges { display: flex; gap: 1.5rem; }
    .footer-badge { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

    /* ─── RESPONSIVE ─── */
    .hamburger-btn { display: none; }

    @media (max-width: 768px) {
      #navbar { padding: 0 1.2rem; }
      .nav-links { display: none; }
      
      /* Hamburger Button */
      .hamburger-btn {
        display: block;
        background: none;
        border: none;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.5rem;
        transition: color 0.2s;
        z-index: 1001;
      }
      
      .hamburger-btn:hover { color: var(--gold); }
      
      .hamburger-btn .close-icon { display: none; }
      .hamburger-btn.active .hamburger-icon { display: none; }
      .hamburger-btn.active .close-icon { display: block; }
      
      .section { padding: 4rem 1.2rem; }
      .story-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .values-grid { grid-template-columns: 1fr; gap: 1rem; }
      .gallery-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        gap: 0.6rem;
        height: auto;
      }
      .gallery-item:nth-child(1) {
        grid-column: 1;
        grid-row: 1;
      }
      .gallery-item:nth-child(2) {
        grid-column: 2;
        grid-row: 1;
      }
      .gallery-item:nth-child(3) {
        grid-column: 1 / 3;
        grid-row: 2;
        aspect-ratio: 16/9;
      }
      .gallery-item:nth-child(4) {
        grid-column: 1;
        grid-row: 3;
      }
      .gallery-item:nth-child(5) {
        grid-column: 2;
        grid-row: 3;
      }
      .gallery-item {
        aspect-ratio: 1/1;
        min-height: 120px;
      }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .page-hero { padding: 7rem 1.2rem 3.5rem; }
      .video-section { padding: 4rem 1.2rem; }
      .gallery-section { padding: 4rem 1.2rem; }
      .values-section { padding: 4rem 1.2rem; }
    }
  </style>
</head>

<body>

  <!-- ═══════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════ -->
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <!-- REPLACE: Add your logo to /public/images/logo.png -->
        <img src="/images/logo.png" alt="Zad Global Trade" onerror="this.style.display='none'" />
        <span>Zad Global Trade</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about" class="active">About</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/certifications">Certifications</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      
      <!-- Hamburger Menu Button (Mobile Only) -->
      <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
        <span class="hamburger-icon">☰</span>
        <span class="close-icon">✕</span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════
       PAGE HERO
  ═══════════════════════════════════════ -->
  <section class="page-hero">
    <span class="page-hero-label">About Us</span>
    <h1>Rooted in India,<br/>Reaching the World</h1>
    <p class="page-hero-sub">A story of trust, quality and global ambition</p>
  </section>

  <!-- ═══════════════════════════════════════
       OUR STORY
  ═══════════════════════════════════════ -->
  <section class="section" style="background: var(--offwhite);">
    <div class="section-inner">
      <div class="story-grid">

        <div class="story-image">
          <!-- REPLACE: Add your story image to /public/images/about-story.jpg -->
          <img
            src="/images/about-story.jpg"
            alt="Zad Global Trade - Our Story"
            onerror="this.outerHTML='<div class=\'story-image-placeholder\'>Add about-story.jpg</div>'"
          />
        </div>

        <div class="story-text">
          <span class="section-label">Our Story</span>
          <h2 class="section-title">Built on Integrity,<br/>Grown with Purpose</h2>
          <p>Zad Global Trade was started to make sourcing and exporting from India more straightforward and reliable for international buyers.</p>
          <p>Before starting independently, ZadGlobalTrade was involved in day-to-day export operations — supporting shipments from documentation to booking and coordination with freight partners. This hands-on experience shapes how we work today.</p>
          <p>We focus on bananas and pomegranates, working with reliable suppliers and managing the process from sourcing to shipment with attention to detail and clear communication.</p>
          <p>In international trade, small gaps can lead to big problems. Our role is to manage those gaps properly — so buyers receive what was agreed, without confusion or delays.</p>
          <a href="/contact" class="story-link">Get In Touch →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MISSION & VALUES
  ═══════════════════════════════════════ -->
  <section class="values-section">
    <div class="values-inner">
      <h2 class="values-heading">What We Stand For</h2>
      <div class="values-grid">

        <div class="value-card">
          <span class="value-icon">🌱</span>
          <h3 class="value-title">Quality First</h3>
          <p class="value-desc">Every piece of produce is graded, inspected and packed to international standards before it leaves our facility. We never compromise on quality.</p>
        </div>

        <div class="value-card">
          <span class="value-icon">🤝</span>
          <h3 class="value-title">Farmer Partnerships</h3>
          <p class="value-desc">We source directly from 200+ partner farms across Maharashtra, ensuring fair prices for farmers and full traceability for our buyers.</p>
        </div>

        <div class="value-card">
          <span class="value-icon">🌍</span>
          <h3 class="value-title">Global Trust</h3>
          <p class="value-desc">Our buyers across 5 nations trust us because we are consistent, transparent and reliable. In Trust We Trade is not just our tagline — it is how we operate every day.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       VIDEO SECTION
  ═══════════════════════════════════════ -->
  <section class="video-section">
    <div class="video-inner">
      <span class="section-label">See Our Process</span>
      <h2 class="video-title">From Farm to Your Shore</h2>

      <div class="video-wrapper">
        <!--
          REPLACE: When you have your YouTube video ready, replace the src below.
          YouTube embed URL format: https://www.youtube.com/embed/YOUR_VIDEO_ID
          Example: https://www.youtube.com/embed/dQw4w9WgXcQ
        -->
        <iframe
          src="https://www.youtube.com/embed/YOUR_VIDEO_ID"
          title="Zad Global Trade - From Farm to Your Shore"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>

        <!-- Placeholder shown until real video is added -->
        <div class="video-placeholder" id="videoPlaceholder">
          <div class="video-play-btn">▶</div>
          <span class="video-placeholder-text">Video Coming Soon</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PHOTO GALLERY — Our Team & Process
  ═══════════════════════════════════════ -->
  <section class="gallery-section">
    <div class="gallery-inner">

      <div class="gallery-header">
        <span class="section-label">Our Team & Process</span>
        <h2 class="section-title" style="text-align: center;">The People Behind Every Box</h2>
      </div>

      <div class="gallery-grid">

        <!-- REPLACE: Add your image to /public/images/gallery-1.jpg (top left) -->
        <div class="gallery-item">
          <img
            src="/images/gallery-1.jpg"
            alt="Zad Global Trade team"
            onerror="this.outerHTML='<div class=\'gallery-placeholder gallery-placeholder-1\'>gallery-1.jpg</div>'"
          />
        </div>

        <!-- REPLACE: Add your image to /public/images/gallery-2.jpg (bottom left) -->
        <div class="gallery-item">
          <img
            src="/images/gallery-2.jpg"
            alt="Pomegranate packing process"
            onerror="this.outerHTML='<div class=\'gallery-placeholder gallery-placeholder-2\'>gallery-2.jpg</div>'"
          />
        </div>

        <!-- REPLACE: Add your MAIN/BEST image to /public/images/gallery-3.jpg (large center) -->
        <div class="gallery-item">
          <img
            src="/images/gallery-3.jpg"
            alt="Fresh pomegranates being packed"
            onerror="this.outerHTML='<div class=\'gallery-placeholder gallery-placeholder-3\'>gallery-3.jpg</div>'"
          />
        </div>

        <!-- REPLACE: Add your image to /public/images/gallery-4.jpg (top right) -->
        <div class="gallery-item">
          <img
            src="/images/gallery-4.jpg"
            alt="Warehouse operations"
            onerror="this.outerHTML='<div class=\'gallery-placeholder gallery-placeholder-4\'>gallery-4.jpg</div>'"
          />
        </div>

        <!-- REPLACE: Add your image to /public/images/gallery-5.jpg (bottom right) -->
        <div class="gallery-item">
          <img
            src="/images/gallery-5.jpg"
            alt="Farm to export process"
