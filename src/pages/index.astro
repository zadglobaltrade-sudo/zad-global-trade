---
// Zad Global Trade - Home Page
// Replace placeholder images in /public/images/ with your actual photos
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>Zad Global Trade — Premium Fresh Produce Exporters from India</title>
  <meta name="description" content="Zad Global Trade exports premium Pomegranates and Bananas from Pune, India to UAE, Saudi Arabia, Malaysia, Bangladesh and Indonesia." />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts: Playfair Display + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --green-dark: #1B4332;
      --green-mid: #2D6A4F;
      --gold: #C9963E;
      --gold-light: #E8B96A;
      --offwhite: #FAF7F2;
      --charcoal: #1C1C1C;
      --grey: #6B6B6B;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--offwhite);
      color: var(--charcoal);
    }

    h1, h2, h3 {
      font-family: 'Playfair Display', serif;
    }

    /* ─── NAVBAR ─── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      transition: background 0.4s ease, box-shadow 0.4s ease;
      padding: 0 3rem;
    }

    #navbar.scrolled {
      background: var(--green-dark);
      box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.12em;
      color: white;
      text-decoration: none;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
      position: relative;
    }

    .nav-links a:hover { color: var(--gold); }

    .nav-links a.active {
      color: white;
      border-bottom: 2px solid var(--gold);
      padding-bottom: 2px;
    }

    .nav-icon {
      color: rgba(255,255,255,0.7);
      font-size: 1.1rem;
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      height: 100vh;
      overflow: hidden;
    }

    .hero-slides {
      display: flex;
      height: 100%;
      transition: transform 0.8s cubic-bezier(0.77, 0, 0.175, 1);
      width: 200%;
    }

    .hero-slide {
      width: 50%;
      height: 100%;
      background-size: cover;
      background-position: center;
      position: relative;
      flex-shrink: 0;
    }

    .hero-slide::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.48);
    }

    /* REPLACE: Add your pomegranate image to /public/images/hero-pomegranate.jpg */
    .hero-slide-1 {
      background-image: url('/images/hero-pomegranate.jpg');
      background-color: #3a1a1a;
    }

    /* REPLACE: Add your banana image to /public/images/hero-banana.jpg */
    .hero-slide-2 {
      background-image: url('/images/hero-banana.jpg');
      background-color: #1a2e1a;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 1rem;
    }

    .hero-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 1.2rem;
      font-weight: 500;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      color: white;
      line-height: 1.15;
      margin-bottom: 1.2rem;
      max-width: 700px;
    }

    .hero-subtitle {
      color: rgba(255,255,255,0.8);
      font-size: 1rem;
      font-weight: 300;
      max-width: 520px;
      line-height: 1.7;
      margin-bottom: 2.4rem;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn-gold {
      background: var(--gold);
      color: white;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      display: inline-block;
    }

    .btn-gold:hover {
      background: var(--gold-light);
      transform: translateY(-1px);
    }

    .btn-outline {
      background: transparent;
      color: white;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      border: 1.5px solid white;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      display: inline-block;
    }

    .btn-outline:hover {
      background: white;
      color: var(--green-dark);
    }

    /* Slider arrows */
    .hero-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      background: transparent;
      border: 1.5px solid rgba(255,255,255,0.5);
      color: white;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1.1rem;
      transition: border-color 0.2s, background 0.2s;
    }

    .hero-arrow:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .hero-arrow-left { left: 2rem; }
    .hero-arrow-right { right: 2rem; }

    /* Slide dots */
    .hero-dots {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      display: flex;
      gap: 0.6rem;
    }

    .hero-dot {
      width: 28px;
      height: 3px;
      background: rgba(255,255,255,0.35);
      border: none;
      cursor: pointer;
      transition: background 0.3s;
      padding: 0;
    }

    .hero-dot.active {
      background: white;
    }

    /* ─── STATS BAR ─── */
    .stats-bar {
      background: var(--green-dark);
      padding: 1.6rem 3rem;
    }

    .stats-bar-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .stat-item {
      text-align: center;
      padding: 0.5rem 1rem;
      border-right: 1px solid rgba(255,255,255,0.12);
    }

    .stat-item:last-child { border-right: none; }

    .stat-number {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--gold);
      display: block;
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .stat-label {
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: rgba(255,255,255,0.65);
      text-transform: uppercase;
      font-weight: 500;
    }

    /* ─── SECTION SHARED ─── */
    .section {
      padding: 6rem 3rem;
    }

    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 0.8rem;
      display: block;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      color: var(--green-dark);
      line-height: 1.2;
    }

    /* ─── ABOUT ─── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .about-image-wrap {
      position: relative;
    }

    .about-image-wrap img {
      width: 100%;
      height: 480px;
      object-fit: cover;
      display: block;
    }

    .about-image-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      background: var(--gold);
      color: white;
      padding: 1.2rem 1.6rem;
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-style: italic;
      max-width: 240px;
      line-height: 1.4;
    }

    .about-text p {
      color: var(--grey);
      line-height: 1.8;
      margin-bottom: 2rem;
      font-size: 0.95rem;
      font-weight: 300;
    }

    .about-features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 1rem;
    }

    .feature-card {
      border: 1px solid rgba(0,0,0,0.08);
      padding: 1.2rem 1rem;
      text-align: center;
      background: white;
    }

    .feature-icon {
      font-size: 1.4rem;
      margin-bottom: 0.6rem;
      display: block;
      color: var(--gold);
    }

    .feature-title {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--green-dark);
      display: block;
      margin-bottom: 0.3rem;
    }

    .feature-desc {
      font-size: 0.78rem;
      color: var(--grey);
      line-height: 1.5;
    }

    /* ─── IMPACT BANNER ─── */
    .impact-section {
      padding: 0 3rem;
      margin-bottom: 6rem;
    }

    .impact-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 420px;
    }

    .impact-image {
      position: relative;
      overflow: hidden;
    }

    /* REPLACE: Add your farm/field image to /public/images/impact-farm.jpg */
    .impact-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .impact-content {
      background: var(--green-dark);
      padding: 3.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .impact-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--gold);
      font-style: italic;
      margin-bottom: 1rem;
    }

    .impact-desc {
      color: rgba(255,255,255,0.75);
      font-size: 0.9rem;
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 2rem;
    }

    .impact-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .impact-stat {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .impact-stat-icon {
      color: var(--gold);
      font-size: 1.1rem;
      margin-top: 2px;
      flex-shrink: 0;
    }

    .impact-stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: white;
      display: block;
      line-height: 1;
    }

    .impact-stat-label {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
      margin-top: 0.2rem;
      display: block;
    }

    /* ─── PRODUCTS ─── */
    .products-section {
      background: var(--offwhite);
      padding: 6rem 3rem;
    }

    .products-header {
      max-width: 1200px;
      margin: 0 auto 3rem;
    }

    .products-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .product-card {
      background: white;
      overflow: hidden;
      position: relative;
      text-decoration: none;
      display: block;
      transition: transform 0.3s ease;
    }

    .product-card:hover { transform: translateY(-4px); }

    .product-card img {
      width: 100%;
      height: 320px;
      object-fit: cover;
      display: block;
    }

    .product-card-body {
      padding: 1.5rem;
      border-bottom: 3px solid var(--green-dark);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .product-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--green-dark);
      display: block;
      margin-bottom: 0.4rem;
    }

    .product-desc {
      font-size: 0.8rem;
      color: var(--grey);
      font-style: italic;
      line-height: 1.5;
    }

    .product-arrow {
      color: var(--gold);
      font-size: 1.2rem;
      flex-shrink: 0;
      margin-top: 4px;
    }

    .products-cta {
      max-width: 1200px;
      margin: 2.5rem auto 0;
      text-align: center;
    }

    .btn-outline-green {
      display: inline-block;
      border: 1.5px solid var(--green-dark);
      color: var(--green-dark);
      padding: 0.85rem 2.5rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }

    .btn-outline-green:hover {
      background: var(--green-dark);
      color: white;
    }

    /* ─── BLOG ─── */
    .blog-section {
      padding: 6rem 3rem;
      background: var(--offwhite);
    }

    .blog-header {
      max-width: 1200px;
      margin: 0 auto 3rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }

    .blog-view-all {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green-dark);
      text-decoration: none;
      font-weight: 600;
      border-bottom: 1px solid var(--green-dark);
      padding-bottom: 2px;
      transition: color 0.2s;
    }

    .blog-view-all:hover { color: var(--gold); border-color: var(--gold); }

    .blog-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .blog-card {
      background: white;
      overflow: hidden;
      text-decoration: none;
      display: block;
      transition: transform 0.3s ease;
    }

    .blog-card:hover { transform: translateY(-4px); }

    /* REPLACE blog card images below with your actual blog post images */
    .blog-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }

    .blog-card-body {
      padding: 1.4rem;
    }

    .blog-category {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      display: block;
      margin-bottom: 0.6rem;
    }

    .blog-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: var(--green-dark);
      line-height: 1.35;
      margin-bottom: 0.6rem;
    }

    .blog-excerpt {
      font-size: 0.8rem;
      color: var(--grey);
      line-height: 1.6;
      margin-bottom: 1rem;
      font-weight: 300;
    }

    .blog-read-more {
      font-size: 0.75rem;
      color: var(--gold);
      font-weight: 600;
      letter-spacing: 0.05em;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--green-dark);
      padding: 4rem 3rem 0;
      border-top: 1px solid var(--gold);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }

    .footer-brand-name {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.12em;
      color: white;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.8rem;
    }

    .footer-tagline {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 1.4rem;
    }

    .footer-socials {
      display: flex;
      gap: 0.6rem;
    }

    .footer-social-btn {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      transition: border-color 0.2s, color 0.2s;
    }

    .footer-social-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .footer-col-title {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 1.2rem;
      display: block;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-links a {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      transition: color 0.2s;
      font-weight: 300;
    }

    .footer-links a:hover { color: white; }

    .footer-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      margin-bottom: 0.8rem;
    }

    .footer-contact-icon {
      color: var(--gold);
      font-size: 0.85rem;
      margin-top: 2px;
      flex-shrink: 0;
    }

    .footer-contact-text {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.5;
      font-weight: 300;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.4rem 0;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.05em;
    }

    .footer-badges {
      display: flex;
      gap: 1.5rem;
    }

    .footer-badge {
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      #navbar { padding: 0 1.2rem; }
      .nav-links { display: none; }
      .section { padding: 4rem 1.2rem; }
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .impact-inner { grid-template-columns: 1fr; }
      .impact-image { height: 240px; }
      .products-grid { grid-template-columns: 1fr; }
      .blog-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .stats-bar-inner { grid-template-columns: repeat(2, 1fr); }
      .blog-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>

<body>

  <!-- ═══════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════ -->
  <nav id="navbar">
    <div class="nav-inner">
<a href="/" class="nav-logo" style="display: flex; align-items: center; gap: 0.6rem;">
  <img src="/images/logo.png" alt="Zad Global Trade" style="height: 44px; width: auto;" />
  <span style="color: white; font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.95rem; letter-spacing: 0.1em; text-transform: uppercase;">Zad Global Trade</span>
</a>    
<ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/certifications">Certifications</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <span class="nav-icon">🌿</span>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════
       HERO SLIDER
  ═══════════════════════════════════════ -->
  <section class="hero" id="hero">
    <div class="hero-slides" id="heroSlides">
      <!-- SLIDE 1: REPLACE background image in CSS .hero-slide-1 with /public/images/hero-pomegranate.jpg -->
      <div class="hero-slide hero-slide-1"></div>
      <!-- SLIDE 2: REPLACE background image in CSS .hero-slide-2 with /public/images/hero-banana.jpg -->
      <div class="hero-slide hero-slide-2"></div>
    </div>

    <!-- Shared hero content overlay -->
    <div class="hero-content">
      <span class="hero-label">Pune, India — Export Ready</span>
      <h1 class="hero-title">Nature's Finest,<br/>Delivered Globally</h1>
      <p class="hero-subtitle">Connecting Indian agriculture to the world through precision sourcing, rigorous quality control, and sustainable export practices.</p>
      <div class="hero-buttons">
        <a href="/products" class="btn-gold">Explore Products</a>
        <a href="/contact" class="btn-outline">Get In Touch</a>
      </div>
    </div>

    <!-- Arrows -->
    <button class="hero-arrow hero-arrow-left" id="prevSlide" aria-label="Previous slide">&#8592;</button>
    <button class="hero-arrow hero-arrow-right" id="nextSlide" aria-label="Next slide">&#8594;</button>

