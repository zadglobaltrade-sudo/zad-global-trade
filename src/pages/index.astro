---
// Zad Global Trade - Home Page (Streamlined)
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>Zad Global Trade — Premium Fresh Produce Exporters from India</title>
  <meta name="description" content="Zad Global Trade exports premium Pomegranates and Bananas from Pune, India to UAE, Saudi Arabia, Malaysia, Bangladesh and Indonesia." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --green-dark: #1B4332;
      --green-mid: #2D6A4F;
      --gold: #C9963E;
      --gold-light: #E8B96A;
      --offwhite: #FAF7F2;
      --charcoal: #1C1C1C;
      --grey: #6B6B6B;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--offwhite);
      color: var(--charcoal);
    }

    h1, h2, h3 { font-family: 'Playfair Display', serif; }

    /* ─── NAVBAR ─── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      transition: background 0.4s ease, box-shadow 0.4s ease;
      padding: 0 3rem;
    }

    #navbar.scrolled {
      background: var(--green-dark);
      box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .nav-logo img { height: 44px; width: auto; }

    .nav-logo span {
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a.active { color: white; border-bottom: 2px solid var(--gold); padding-bottom: 2px; }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      height: 100vh;
      overflow: hidden;
    }

    .hero-slides {
      display: flex;
      height: 100%;
      transition: transform 0.8s cubic-bezier(0.77, 0, 0.175, 1);
      width: 200%;
    }

    .hero-slide {
      width: 50%;
      height: 100%;
      background-size: cover;
      background-position: center;
      position: relative;
      flex-shrink: 0;
    }

    .hero-slide::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.48);
    }

    .hero-slide-1 { background-image: url('/images/hero-pomegranate.jpg'); background-color: #3a1a1a; }
    .hero-slide-2 { background-image: url('/images/hero-banana.jpg'); background-color: #1a2e1a; }

    .hero-content {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 1rem;
    }

    .hero-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 1.2rem;
      font-weight: 500;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      color: white;
      line-height: 1.15;
      margin-bottom: 1.2rem;
      max-width: 700px;
    }

    .hero-subtitle {
      color: rgba(255,255,255,0.8);
      font-size: 1rem;
      font-weight: 300;
      max-width: 520px;
      line-height: 1.7;
      margin-bottom: 2.4rem;
    }

    .hero-buttons { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

    .btn-gold {
      background: var(--gold);
      color: white;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s;
      border: none;
    }

    .btn-gold:hover { background: var(--gold-light); }

    .btn-outline {
      background: transparent;
      color: white;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1.5px solid white;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }

    .btn-outline:hover { background: white; color: var(--green-dark); }

    /* Slider UI */
    .hero-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      background: transparent;
      border: 1.5px solid rgba(255,255,255,0.5);
      color: white;
      width: 44px;
      height: 44px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-arrow-left { left: 2rem; }
    .hero-arrow-right { right: 2rem; }

    /* ─── ABOUT ─── */
    .section { padding: 6rem 3rem; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-label { font-size: 0.72rem; letter-spacing: 0.2em; color: var(--gold); text-transform: uppercase; font-weight: 600; margin-bottom: 0.8rem; display: block; }
    .section-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3rem); color: var(--green-dark); line-height: 1.2; }

    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .about-image-wrap { position: relative; }
    .about-image-wrap img { width: 100%; height: 480px; object-fit: cover; }
    .about-image-caption {
        position: absolute; bottom: 0; left: 0;
        background: var(--gold); color: white;
        padding: 1.2rem; font-family: 'Playfair Display', serif; font-style: italic; max-width: 240px;
    }
    .about-text p { color: var(--grey); line-height: 1.8; margin-bottom: 2rem; font-size: 0.95rem; font-weight: 300; }
    .about-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1rem; }
    .feature-card { border: 1px solid rgba(0,0,0,0.08); padding: 1.2rem 1rem; text-align: center; background: white; }
    .feature-title { font-size: 0.72rem; font-weight: 600; color: var(--green-dark); display: block; margin-bottom: 0.3rem; }
    .feature-desc { font-size: 0.78rem; color: var(--grey); line-height: 1.5; }

    /* ─── PRODUCTS ─── */
    .products-section { background: var(--offwhite); padding: 6rem 3rem; }
    .products-header { max-width: 1200px; margin: 0 auto 3rem; }
    .products-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 1200px; margin: 0 auto; }
    .product-card { background: white; text-decoration: none; transition: transform 0.3s; overflow: hidden; }
    .product-card:hover { transform: translateY(-4px); }
    .product-card img { width: 100%; height: 320px; object-fit: cover; }
    .product-card-body { padding: 1.5rem; border-bottom: 3px solid var(--green-dark); display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; }
    .product-name { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--green-dark); display: block; }
    .product-desc { font-size: 0.8rem; color: var(--grey); font-style: italic; }
    .btn-outline-green { display: inline-block; border: 1.5px solid var(--green-dark); color: var(--green-dark); padding: 0.85rem 2.5rem; font-size: 0.78rem; font-weight: 600; text-decoration: none; margin-top: 2.5rem; }

    /* ─── FOOTER ─── */
    footer { background: var(--green-dark); padding: 4rem 3rem 0; border-top: 1px solid var(--gold); }
    .footer-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; }
    .footer-brand-name { font-weight: 600; color: white; text-transform: uppercase; display: block; margin-bottom: 0.8rem; }
    .footer-tagline { font-size: 0.82rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin-bottom: 1.4rem; }
    .footer-col-title { font-size: 0.68rem; color: var(--gold); font-weight: 600; text-transform: uppercase; margin-bottom: 1.2rem; display: block; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-links a { font-size: 0.82rem; color: rgba(255,255,255,0.6); text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.08); padding: 1.4rem 0; display: flex; justify-content: space-between; max-width: 1200px; margin: 0 auto; }
    .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.35); }

    @media (max-width: 768px) {
      #navbar { padding: 0 1.2rem; }
      .nav-links { display: none; }
      .about-grid, .products-grid, .footer-inner { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/images/logo.png" alt="Zad Global Trade" onerror="this.style.display='none'" />
        <span>Zad Global Trade</span>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/certifications">Certifications</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <span class="nav-icon">🌿</span>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-slides" id="heroSlides">
      <div class="hero-slide hero-slide-1"></div>
      <div class="hero-slide hero-slide-2"></div>
    </div>
    <div class="hero-content">
      <span class="hero-label">Pune, India — Export Ready</span>
      <h1 class="hero-title">Nature's Finest,<br/>Delivered Globally</h1>
      <p class="hero-subtitle">Connecting Indian agriculture to the world through precision sourcing and sustainable export practices.</p>
      <div class="hero-buttons">
        <a href="/products" class="btn-gold">Explore Products</a>
        <a href="/contact" class="btn-outline">Get In Touch</a>
      </div>
    </div>
    <button class="hero-arrow hero-arrow-left" id="prevSlide">&#8592;</button>
    <button class="hero-arrow hero-arrow-right" id="nextSlide">&#8594;</button>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-image-wrap">
          <img src="/images/about-produce.jpg" alt="Fresh Produce" />
          <div class="about-image-caption">Tradition meets<br/>Modern Commerce.</div>
        </div>
        <div class="about-text">
          <span class="section-label">Who We Are</span>
          <h2 class="section-title" style="margin-bottom: 1.4rem;">Bridging the Gap Between Soil and Soul</h2>
          <p>Based in Pune, Zad Global Trade specializes in sourcing premium pomegranates and bananas directly from farmers, ensuring international standards of freshness.</p>
          <div class="about-features">
            <div class="feature-card"><span>🌱</span><span class="feature-title">Farm Fresh</span></div>
            <div class="feature-card"><span>🚢</span><span class="feature-title">Export Ready</span></div>
            <div class="feature-card"><span>✅</span><span class="feature-title">Verified</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="products-section">
    <div class="products-header">
      <span class="section-label">Our Products</span>
      <h2 class="section-title">The Harvest Portfolio</h2>
    </div>
    <div class="products-grid">
      <a href="/products#pomegranates" class="product-card">
        <img src="/images/product-pomegranate.jpg" alt="Pomegranates" onerror="this.style.background='#8B1A1A'; this.style.display='block'; this.style.height='320px'; this.removeAttribute('src')" />
        <div class="product-card-body">
          <div>
            <span class="product-name">Bhagwa Pomegranates</span>
            <span class="product-desc">Deep red colour and superior sweetness from Maharashtra.</span>
          </div>
          <span>→</span>
        </div>
      </a>
      <a href="/products#bananas" class="product-card">
        <img src="/images/product-banana.jpg" alt="Bananas" onerror="this.style.background='#7A6A00'; this.style.display='block'; this.style.height='320px'; this.removeAttribute('src')" />
        <div class="product-card-body">
          <div>
            <span class="product-name">Grand Naine Bananas</span>
            <span class="product-desc">Premium Cavendish variety for long-distance transit.</span>
          </div>
          <span>→</span>
        </div>
      </a>
    </div>
    <div style="text-align: center;">
      <a href="/products" class="btn-outline-green">View All Products</a>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div>
        <span class="footer-brand-name">Zad Global Trade</span>
        <p class="footer-tagline">Exporting India's premium agricultural heritage to the global stage.</p>
      </div>
      <div>
        <span class="footer-col-title">Navigation</span>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <span class="footer-col-title">Contact</span>
        <ul class="footer-links">
          <li><a href="mailto:zadglobaltrade@gmail.com">zadglobaltrade@gmail.com</a></li>
          <li>Pune, Maharashtra, India</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2026 Zad Global Trade. All rights reserved.</span>
    </div>
  </footer>

  <script is:inline>
    // Navbar Scroll Effect
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (window.scrollY > 50) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    });

    // Simple Hero Slider
    let currentSlide = 0;
    const slides = document.getElementById('heroSlides');
    const totalSlides = 2;

    function updateSlider() {
      slides.style.transform = `translateX(-${currentSlide * 50}%)`;
    }

    document.getElementById('nextSlide').addEventListener('click', () => {
      currentSlide = (currentSlide + 1) % totalSlides;
      updateSlider();
    });

    document.getElementById('prevSlide').addEventListener('click', () => {
      currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
      updateSlider();
    });
  </script>
</body>
</html>